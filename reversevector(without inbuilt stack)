#include <iostream>
#include <vector>
using namespace std;
#define MAX 100 
class Stack {
    int arr[MAX];
    int top;
public:
    Stack() {
        top = -1;
    }
    void push(int x) {
        if (top >= MAX - 1) {
            cout << "Stack Overflow\n";
            return;
        }
        arr[++top] = x;
    }
    int pop() {
        if (top < 0) {
            cout << "Stack Underflow\n";
            return -1;
        }
        return arr[top--];
    }
    bool isEmpty() {
        return (top < 0);
    }
};
void reverseVector(vector<int>& vec) {
    Stack st;
    for (int i = 0; i < vec.size(); ++i) {
        st.push(vec[i]);
    }
    for (int i = 0; i < vec.size(); ++i) {
        vec[i] = st.pop();
    }
}
