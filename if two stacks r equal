#include <iostream>
#include <stack>
using namespace std;
bool areStacksEqual(stack<int> s1, stack<int> s2) {
    if (s1.size() != s2.size()) {
        return false;
    }
    while (!s1.empty()) {
        if (s1.top() != s2.top()) {
            return false;
        }
        s1.pop();
        s2.pop();
    }
    return true;
int main() {
    stack<int> stack1;
    stack<int> stack2;
    stack1.push(10);
    stack1.push(20);
    stack1.push(30);
    stack2.push(10);
    stack2.push(20);
    stack2.push(30);
    if (areStacksEqual(stack1, stack2)) {
        cout << "Stacks are equal" << endl;
    } else {
        cout << "Stacks are not equal" << endl;
    }
    return 0;
}
