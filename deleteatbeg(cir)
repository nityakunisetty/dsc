#include <iostream>
using namespace std;
struct node {
    int data;
    node* next;
};
class linkedlist {
private:
    node* head;
public:
    linkedlist() {
        head = NULL;
    }
    void deleteatbegin() {
        if (head == NULL)
            return;
        if (head->next == head) {
            delete head;
            head = NULL;
            return;
        }
        node* temp = head;
        node* prev = head;
        while (prev->next != head) {
            prev = prev->next;
        head = head->next;
        prev->next = head;
        delete temp;
    }
    void display() {
        if (head == NULL)
            return;
        node* temp = head;
        do {
            cout << temp->data << " ";
            temp = temp->next;
        } while (temp != head);
        cout << endl;
    }
    Node* insertatBeginning(Node* head, int value) {
    Node* newNode = new Node();
    newNode->data = value;
    if (head == NULL) {
        newNode->next = newNode;
        return newNode;
    }
    Node* temp = head;
    while (temp->next != head) {
        temp = temp->next;
    }
    temp->next = newNode;
    newNode->next = head;
    return newNode;
    }
};
int main() {
    linkedlist l;
    l.insert(10);
    l.insert(20);
    l.insert(30);
    l.display();
    l.deleteatbegin();
    l.display();
    return 0;
}
